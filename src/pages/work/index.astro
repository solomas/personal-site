---
import Layout from "../../components/Layout.astro";
import StreamTag from "../../components/StreamTag.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import { getCollection } from "astro:content";
const entries = await getCollection("work", ({ data }) => data.status !== "archived");
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title="Work">
  <section class="stream-header">
    <div class="stream-header__top">
      <SectionLabel label="Work index" number="01" kicker="Professional practice" />
      <StreamTag stream="work" />
    </div>
    <h1>Work</h1>
    <p class="stream-header__lede">Professional projects, consulting and programme design.</p>
  </section>

  <ul class="entry-list">
    {entries.map(entry => (
      <li>
        <a href={`/work/${entry.id}/`} class="entry-link">
          <span class="entry-link__date meta">
            {entry.data.date.toLocaleDateString("en-GB", { year: "numeric", month: "short" })}
          </span>
          <span class="entry-link__title">{entry.data.title}</span>
          <span class="entry-link__summary">{entry.data.summary}</span>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .stream-header {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-16) var(--space-8) var(--space-12);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }
  .stream-header__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }
  .stream-header h1 {
    font-size: var(--text-6xl);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: var(--space-6);
  }
  .stream-header__lede {
    font-size: var(--text-xl);
    color: var(--color-muted);
    max-width: 50ch;
  }
  .entry-list {
    list-style: none;
    padding: 0 var(--space-8);
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    gap: 0;
  }
  .entry-link {
    display: grid;
    grid-template-columns: 140px 1fr;
    column-gap: var(--space-8);
    row-gap: var(--space-2);
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    transition: padding-left var(--transition), color var(--transition);
  }
  .entry-link:hover {
    padding-left: var(--space-4);
  }
  .entry-link:hover .entry-link__title {
    color: var(--color-accent);
  }
  .entry-link__date {
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: start;
    padding-top: 4px;
  }
  .entry-link__title {
    grid-column: 2;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .entry-link__summary {
    grid-column: 2;
    color: var(--color-muted);
    max-width: 60ch;
  }
  @media (max-width: 600px) {
    .entry-link { grid-template-columns: 1fr; }
    .entry-link__date { grid-row: 1; }
  }
</style>
