---
import Layout from "../../components/Layout.astro";
import StreamTag from "../../components/StreamTag.astro";
import { getCollection, render } from "astro:content";
export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Layout title={entry.data.title}>
  <article class="entry">
    <p class="entry__back"><a href="/projects/">Back to projects</a></p>
    <header class="entry__header">
      <StreamTag stream="projects" />
      <div class="entry-rule" aria-hidden="true"></div>
      <h1>{entry.data.title}</h1>
      <p class="entry__summary">{entry.data.summary}</p>
    </header>
    <div class="entry__body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .entry {
    max-width: var(--content-width);
    margin: var(--space-16) auto;
    padding: 0 var(--space-8);
  }
  .entry__back {
    margin-bottom: var(--space-8);
  }
  .entry__back a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-decoration: none;
  }
  .entry__back a:hover {
    color: var(--color-accent);
  }
  .entry__header {
    margin-bottom: var(--space-12);
  }
  .entry__header :global(.stream-tag) {
    margin-bottom: var(--space-6);
  }
  .entry-rule {
    width: 4rem;
    height: 3px;
    background: var(--color-accent);
    margin-bottom: 1.5rem;
  }
  .entry__header h1 {
    font-size: var(--text-5xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--space-4);
  }
  .entry__summary {
    font-size: var(--text-xl);
    color: var(--color-muted);
  }
  .entry__body {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }
  .entry__body p {
    margin-bottom: var(--space-6);
  }
  .entry__body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: opacity 150ms ease;
  }
  .entry__body :global(a:hover) {
    opacity: 0.75;
  }
</style>
