---
import Layout from "../../components/Layout.astro";
import StreamTag from "../../components/StreamTag.astro";
import { getCollection } from "astro:content";
const entries = await getCollection("projects", ({ data }) => data.status !== "archived");
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title="Projects">
  <section class="stream-header">
    <StreamTag stream="projects" />
    <h1>Projects</h1>
    <p class="stream-header__lede">Side work, experiments and things made out of curiosity.</p>
  </section>

  <ul class="entry-list">
    {entries.map(entry => (
      <li>
        <a href={`/projects/${entry.id}/`} class="entry-link">
          <span class="entry-link__date meta">
            {entry.data.date.toLocaleDateString("en-GB", { year: "numeric", month: "short" })}
          </span>
          <span class="entry-link__title">{entry.data.title}</span>
          <span class="entry-link__summary">{entry.data.summary}</span>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .stream-header {
    padding-bottom: var(--space-16);
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }
  .stream-header :global(.stream-tag) {
    margin-bottom: var(--space-6);
  }
  .stream-header h1 {
    font-size: var(--text-6xl);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: var(--space-6);
  }
  .stream-header__lede {
    font-size: var(--text-xl);
    color: var(--color-muted);
    max-width: 50ch;
  }
  .entry-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .entry-link {
    display: grid;
    grid-template-columns: 140px 1fr;
    column-gap: var(--space-8);
    row-gap: var(--space-2);
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    transition: padding-left var(--transition), color var(--transition);
  }
  .entry-link:hover {
    padding-left: var(--space-4);
  }
  .entry-link:hover .entry-link__title {
    color: var(--color-accent);
  }
  .entry-link__date {
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: start;
    padding-top: 4px;
  }
  .entry-link__title {
    grid-column: 2;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .entry-link__summary {
    grid-column: 2;
    color: var(--color-muted);
    max-width: 60ch;
  }
  @media (max-width: 600px) {
    .entry-link { grid-template-columns: 1fr; }
    .entry-link__date { grid-row: 1; }
  }
</style>
