---
import Layout from "../../components/Layout.astro";
import StreamTag from "../../components/StreamTag.astro";
import SectionLabel from "../../components/SectionLabel.astro";
import { getCollection } from "astro:content";
const entries = await getCollection("projects", ({ data }) => data.status !== "archived");
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title="Projects">
  <section class="stream-header">
    <div class="stream-header__top">
      <SectionLabel label="Projects index" number="01" kicker="Side work and experiments" />
      <StreamTag stream="projects" />
    </div>
    <h1>Projects</h1>
    <p class="stream-header__lede">Side work, experiments and things made out of curiosity.</p>
  </section>

  <ul class="entry-list">
    {entries.map(entry => (
      <li>
        <a href={`/projects/${entry.id}/`} class="entry-link">
          <span class="entry-link__date meta">
            {entry.data.date.toLocaleDateString("en-GB", { year: "numeric", month: "short" })}
          </span>
          <span class="entry-link__title">{entry.data.title}</span>
          <span class="entry-link__summary">{entry.data.summary}</span>
        </a>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .stream-header {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-16) var(--space-8) var(--space-12);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }
  .stream-header__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }
  .stream-header h1 {
    font-size: var(--text-6xl);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: var(--space-6);
  }
  .stream-header__lede {
    font-size: var(--text-xl);
    color: var(--color-muted);
    max-width: 50ch;
  }
  .entry-list {
    list-style: none;
    padding: 0 var(--space-8);
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    gap: 0;
  }
  .entry-link {
    display: grid;
    grid-template-columns: 140px 1fr;
    column-gap: var(--space-8);
    row-gap: var(--space-2);
    /* Reserve left padding (bar width plus a gap) so the gilt hover bar sits
       clear of the text and toggling it causes no layout shift. */
    padding: var(--space-8) 0 var(--space-8) var(--space-4);
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    /* Load reveal: rise and fade in with a light per-item stagger. backwards
       fill hides the row during its delay then hands back to the base styles,
       so the hover transform below is never blocked by a finished animation. */
    animation: riseIn 340ms var(--ease-out) backwards;
    transition: transform 180ms var(--ease-out), box-shadow 180ms var(--ease-out), color var(--transition);
  }
  /* Restrained echo of the arch hover: a lift and a gilt left edge drawn in the
     reserved left padding, so it never overlaps the text. */
  .entry-link:hover {
    transform: translateY(-4px);
    box-shadow: inset 3px 0 0 var(--color-accent);
  }
  .entry-link:hover .entry-link__title {
    color: var(--color-accent);
  }
  .entry-list li:nth-child(1) .entry-link { animation-delay: 40ms; }
  .entry-list li:nth-child(2) .entry-link { animation-delay: 80ms; }
  .entry-list li:nth-child(3) .entry-link { animation-delay: 120ms; }
  .entry-list li:nth-child(4) .entry-link { animation-delay: 160ms; }
  .entry-list li:nth-child(5) .entry-link { animation-delay: 200ms; }
  .entry-list li:nth-child(n+6) .entry-link { animation-delay: 240ms; }
  @keyframes riseIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .entry-link { animation: none; }
    .entry-link:hover { transform: none; }
  }
  .entry-link__date {
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: start;
    padding-top: 4px;
  }
  .entry-link__title {
    grid-column: 2;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .entry-link__summary {
    grid-column: 2;
    color: var(--color-muted);
    max-width: 60ch;
  }
  @media (max-width: 600px) {
    .entry-link { grid-template-columns: 1fr; }
    .entry-link__date { grid-row: 1; }
  }
</style>
