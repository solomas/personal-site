---
import Layout from "../components/Layout.astro";
import StreamTag from "../components/StreamTag.astro";
---
<Layout title="Tomás van Gorp">
  <section class="hero">
    <p class="hero__eyebrow">
      <span class="meta">est. 2026 / planetary health / open work</span>
    </p>
    <h1 class="hero__name">Tomás<br/>van Gorp</h1>
    <p class="hero__lede">
      I build, advise and research at the intersection of health, environment and policy.
    </p>
  </section>

  <section class="streams">
    <a href="/projects/" class="stream-card stream-card--projects">
      <StreamTag stream="projects" />
      <h2 class="stream-card__title">Projects</h2>
      <p class="stream-card__desc">Side work and experiments. Things made out of curiosity.</p>
      <span class="stream-card__cta">See projects &rarr;</span>
    </a>
    <a href="/work/" class="stream-card stream-card--work">
      <StreamTag stream="work" />
      <h2 class="stream-card__title">Work</h2>
      <p class="stream-card__desc">Professional projects, consulting and programme design.</p>
      <span class="stream-card__cta">See work &rarr;</span>
    </a>
    <a href="/research/" class="stream-card stream-card--research">
      <StreamTag stream="research" />
      <h2 class="stream-card__title">Research</h2>
      <p class="stream-card__desc">Doctoral work, papers, talks and notes from the field.</p>
      <span class="stream-card__cta">See research &rarr;</span>
    </a>
  </section>
</Layout>

<style>
  .hero {
    padding-top: var(--space-12);
    padding-bottom: var(--space-32);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-16);
  }
  .hero__eyebrow {
    margin-bottom: var(--space-8);
  }
  .hero__name {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-8);
  }
  .hero__lede {
    font-size: var(--text-xl);
    color: var(--color-muted);
    max-width: 40ch;
    line-height: var(--leading-snug);
  }

  .streams {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }
  .stream-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: var(--space-8);
    row-gap: var(--space-2);
    padding: var(--space-12) 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: padding-left var(--transition);
    align-items: baseline;
  }
  .stream-card:hover {
    padding-left: var(--space-6);
  }
  .stream-card > :global(.stream-tag) {
    grid-column: 1;
    grid-row: 1;
    align-self: center;
  }
  .stream-card__title {
    grid-column: 2;
    grid-row: 1;
    font-size: var(--text-5xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .stream-card__desc {
    grid-column: 2;
    grid-row: 2;
    color: var(--color-muted);
    font-size: var(--text-lg);
    max-width: 50ch;
  }
  .stream-card__cta {
    grid-column: 3;
    grid-row: 1 / span 2;
    align-self: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
    transition: color var(--transition), transform var(--transition);
  }
  .stream-card:hover .stream-card__cta {
    color: var(--color-accent);
    transform: translateX(4px);
  }
  .stream-card:hover .stream-card__title {
    color: var(--color-accent);
  }

  @media (max-width: 720px) {
    .stream-card {
      grid-template-columns: auto 1fr;
    }
    .stream-card__title { font-size: var(--text-4xl); }
    .stream-card__cta { display: none; }
  }
</style>
