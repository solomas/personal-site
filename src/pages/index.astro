---
import Layout from "../components/Layout.astro";
import Triptych from "../components/Triptych.astro";
---
<Layout title="Tomás van Gorp" hideNav={true}>
  <section class="home">
    <div class="home__intro">
      <h1 class="home__name">Tomás van Gorp</h1>
      <p class="home__lede">I work, advise and research at the intersection of science, society and environment.</p>
    </div>
    <Triptych />
  </section>
</Layout>

<style>
  /* The triptych is the landing hero. The section fills the viewport under the
     header and centres the art, with a slim intro above so the art leads. */
  .home {
    min-height: calc(100svh - 5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4) var(--space-4);
    text-align: center;
  }

  .home__intro {
    max-width: 52ch;
  }
  .home__name {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .home__lede {
    margin-top: var(--space-2);
    margin-inline: auto;
    max-width: 44ch;
    color: var(--color-muted);
    font-size: clamp(0.85rem, 1.3vw, 1rem);
    line-height: 1.35;
  }

  /* The art dominates: cap its width by viewport height so the tall arches fill
     close to the full screen yet never clip or force scroll. Frame height is
     roughly 0.67x its width, so this budget keeps the whole frame (gilded edge
     included) on screen. Width still wins on narrow screens, where the panels
     are the carousel. Drop the component's own vertical padding here so the
     height budget is spent on the art. */
  .home :global(.triptych) {
    width: min(100%, var(--page-width), calc(149svh - 380px));
    padding-top: 0;
    padding-bottom: 0;
  }

  @media (max-width: 720px) {
    .home {
      min-height: calc(100svh - 5rem);
      justify-content: flex-start;
      padding-top: var(--space-8);
    }
  }
</style>
