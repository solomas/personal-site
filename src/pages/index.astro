---
import Layout from "../components/Layout.astro";
import SectionLabel from "../components/SectionLabel.astro";
import Triptych from "../components/Triptych.astro";
---
<Layout title="Tomás van Gorp">
  <section class="hero">
    <div class="hero__top">
      <SectionLabel label="Introduction" number="01" kicker="Independent practice" />
      <p class="hero__location meta">Based in Lisbon</p>
    </div>
    <h1 class="hero__name">Tomás<br/>van Gorp</h1>
    <p class="hero__lede">
      I work, advise and research at the intersection of science, society and environment.
    </p>
  </section>

  <Triptych />
</Layout>

<style>
  .hero {
    padding: var(--space-16) var(--space-8) var(--space-24);
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .hero__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    margin-bottom: var(--space-16);
    flex-wrap: wrap;
  }
  .hero__location {
    text-align: right;
  }
  .hero__name {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 700;
    line-height: 0.88;
    letter-spacing: -0.045em;
    margin-bottom: var(--space-12);
  }
  .hero__lede {
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    color: var(--color-muted);
    max-width: 38ch;
    line-height: 1.3;
  }

  @media (max-width: 720px) {
    .hero__location { text-align: left; }
  }
</style>
