---
import Layout from "../components/Layout.astro";
import Triptych from "../components/Triptych.astro";
---
<Layout title="Tomás van Gorp" hideNav={true}>
  <section class="home">
    <div class="home__intro">
      <h1 class="home__name">I work, advise and research where <span class="accent">science</span>, <span class="accent">society</span> and <span class="accent">environment</span> meet.</h1>
    </div>
    <Triptych />
  </section>
</Layout>

<style>
  /* The triptych is the landing hero. The section fills the viewport under the
     header and centres the art, with a slim intro above so the art leads. */
  .home {
    min-height: calc(100svh - 5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* Generous, viewport-scaled breathing room between the hero line and the
       first row so the sentence is not crowded by the big type below. */
    gap: clamp(var(--space-6), 5vh, var(--space-16));
    padding: var(--space-3) var(--space-4) var(--space-4);
    text-align: center;
  }

  .home__intro {
    max-width: 100%;
  }
  /* The hero is a single sentence, sized large but a touch under a two-word
     headline since it wraps to a few lines. Centred, tight tracking. */
  /* Lighter base weight so the three accent words carry the line. */
  .home__name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin-inline: auto;
    max-width: 24ch;
    /* Yellow theme: black via the accent token, readable on the amber page. */
    color: var(--color-accent);
  }
  /* Flip (black) theme: white reads cleaner on pure black than the gold accent. */
  :global([data-theme="flip"]) .home__name {
    color: #ffffff;
  }
  /* science / society / environment light up: yellow accent in the flip theme,
     and in the yellow theme (where the accent token is black, same as the text)
     the bold weight against the lighter rest carries the emphasis. */
  .home__name .accent {
    color: var(--color-accent);
    font-weight: 700;
  }

  /* The triptych is a left-flush cut-off composition that bleeds off the right
     edge, so it stretches to the full hero width instead of being centred and
     width-capped. It owns its own height budget internally (see Triptych.astro).
     The intro above stays centred, a deliberate contrast against the left-flush
     art. */
  .home :global(.triptych) {
    align-self: stretch;
    padding-top: 0;
    padding-bottom: 0;
  }

  @media (max-width: 720px) {
    .home {
      min-height: calc(100svh - 5rem);
      justify-content: flex-start;
      padding-top: var(--space-8);
    }
    .home__name {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }
  }
</style>
