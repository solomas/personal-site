---
import "../styles/global.css";
import Fonts from "./Fonts.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Cursor from "./Cursor.astro";

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
}

const { title, description = "Tomás van Gorp. Projects, work, research.", hideNav = false } = Astro.props;
const pathname = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          if (saved === "flip") {
            document.documentElement.setAttribute("data-theme", "flip");
          }
        } catch (e) {}
      })();
    </script>
    <Fonts />
  </head>
  <body>
    <Cursor />
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__name">Tomás van Gorp</a>
        {!hideNav && (
          <nav class="site-header__nav" aria-label="Primary">
            <a href="/projects/" class:list={["nav-link", { active: pathname.startsWith("/projects") }]}>Projects</a>
            <a href="/work/" class:list={["nav-link", { active: pathname.startsWith("/work") }]}>Work</a>
            <a href="/research/" class:list={["nav-link", { active: pathname.startsWith("/research") }]}>Research</a>
            <a href="/contact/" class:list={["nav-link", { active: pathname.startsWith("/contact") }]}>Contact</a>
          </nav>
        )}
        <ThemeToggle />
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span class="meta">Built in the open. Last updated {new Date().getFullYear()}.</span>
        <a href="/contact/" class="site-footer__contact meta">Contact</a>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-6) var(--space-8);
      }
      .site-header__inner {
        max-width: var(--page-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-6);
        flex-wrap: wrap;
      }
      .site-header__name {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: 600;
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .site-header__name:hover {
        color: var(--color-accent);
      }
      .site-header__nav {
        display: flex;
        gap: var(--space-6);
        flex: 1;
        position: relative;
      }
      .nav-link {
        position: relative;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        text-decoration: none;
        color: var(--color-muted);
        letter-spacing: 0.02em;
        padding-bottom: 4px;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 2px;
        background-color: var(--color-text);
        transform: scaleX(0);
        transform-origin: left center;
        transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .nav-link:hover {
        color: var(--color-text);
      }
      .nav-link:hover::after {
        transform: scaleX(1);
      }
      .nav-link.active {
        color: var(--color-text);
      }
      .nav-link.active::after {
        transform: scaleX(1);
        background-color: var(--color-text);
      }
      .site-main {
        min-height: 60vh;
        width: 100%;
      }
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-8);
        margin-top: var(--space-24);
      }
      .site-footer__inner {
        max-width: var(--page-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-4);
        flex-wrap: wrap;
      }
      .site-footer__contact {
        text-decoration: none;
      }
      .site-footer__contact:hover {
        color: var(--color-accent);
      }
    </style>
  </body>
</html>
