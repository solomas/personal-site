---
// Static triptych altarpiece. Open state only, no behaviour yet.
// Three pointed gothic arches: Research, Work (dominant), Projects.
// Palette is fixed and internal to this component. It does not pull --color-bg
// so the altarpiece reads the same in both site themes.
---
<section class="triptych" aria-label="Three streams of work">
  <div class="triptych__frame">

    <a href="/research/" class="panel panel--wing">
      <svg class="panel__art" viewBox="0 0 200 340" role="img" aria-label="Research panel" focusable="false">
        <path class="panel__framepath" d="M8 332 L8 132 Q8 44 100 12 Q192 44 192 132 L192 332 Z" />
        <path class="panel__ground" d="M18 322 L18 134 Q18 56 100 26 Q182 56 182 134 L182 322 Z" />
        <!-- Research emblem: open eye, three observation rays, root sprout -->
        <g stroke="var(--tri-gold)" stroke-width="3" stroke-linecap="round">
          <line x1="100" y1="86" x2="100" y2="60" />
          <line x1="78" y1="90" x2="68" y2="66" />
          <line x1="122" y1="90" x2="132" y2="66" />
        </g>
        <path d="M64 118 Q100 96 136 118 Q100 140 64 118 Z" fill="var(--tri-parchment)" stroke="var(--tri-deep)" stroke-width="3" />
        <circle cx="100" cy="118" r="14" fill="var(--tri-teal)" />
        <circle cx="100" cy="118" r="6" fill="var(--tri-dark)" />
        <circle cx="95" cy="113" r="2.5" fill="var(--tri-parchment)" />
        <path d="M100 146 V176" stroke="var(--tri-leaf)" stroke-width="3" fill="none" stroke-linecap="round" />
        <path d="M100 160 C86 156 80 148 82 140 C92 144 100 150 100 160 Z" fill="var(--tri-sage)" stroke="var(--tri-leaf)" stroke-width="1.5" />
        <path d="M100 160 C114 156 120 148 118 140 C108 144 100 150 100 160 Z" fill="var(--tri-sage)" stroke="var(--tri-leaf)" stroke-width="1.5" />
        <path d="M100 176 q-8 6 -14 8 M100 176 q8 6 14 8" stroke="var(--tri-leaf)" stroke-width="2.5" fill="none" stroke-linecap="round" />
      </svg>
      <div class="panel__caption">
        <h2 class="panel__name">Research</h2>
        <p class="panel__desc">Doctoral work in planetary health.</p>
      </div>
    </a>

    <a href="/work/" class="panel panel--centre">
      <svg class="panel__art" viewBox="0 0 200 340" role="img" aria-label="Work panel" focusable="false">
        <path class="panel__framepath" d="M8 332 L8 132 Q8 44 100 12 Q192 44 192 132 L192 332 Z" />
        <path class="panel__ground" d="M18 322 L18 134 Q18 56 100 26 Q182 56 182 134 L182 322 Z" />
        <!-- Work emblem: sage sphere with meridians, three figures on top -->
        <circle cx="100" cy="138" r="34" fill="var(--tri-sage)" stroke="var(--tri-leaf)" stroke-width="2.5" />
        <ellipse cx="100" cy="138" rx="34" ry="11" fill="none" stroke="var(--tri-leaf)" stroke-width="1.8" />
        <ellipse cx="100" cy="138" rx="13" ry="34" fill="none" stroke="var(--tri-leaf)" stroke-width="1.8" />
        <line x1="100" y1="104" x2="100" y2="172" stroke="var(--tri-leaf)" stroke-width="1.8" />
        <g>
          <circle cx="84" cy="92" r="4.5" fill="var(--tri-flesh)" />
          <path d="M79 105 L81 96 L87 96 L89 105 Z" fill="var(--tri-oxblood)" />
          <circle cx="100" cy="89" r="4.5" fill="var(--tri-flesh)" />
          <path d="M95 102 L97 93 L103 93 L105 102 Z" fill="var(--tri-oxblood)" />
          <circle cx="116" cy="92" r="4.5" fill="var(--tri-flesh)" />
          <path d="M111 105 L113 96 L119 96 L121 105 Z" fill="var(--tri-oxblood)" />
        </g>
      </svg>
      <div class="panel__caption">
        <h2 class="panel__name">Work</h2>
        <p class="panel__desc">Consulting and programme design.</p>
      </div>
    </a>

    <a href="/projects/" class="panel panel--wing">
      <svg class="panel__art" viewBox="0 0 200 340" role="img" aria-label="Projects panel" focusable="false">
        <path class="panel__framepath" d="M8 332 L8 132 Q8 44 100 12 Q192 44 192 132 L192 332 Z" />
        <path class="panel__ground" d="M18 322 L18 134 Q18 56 100 26 Q182 56 182 134 L182 322 Z" />
        <!-- Projects emblem: green stalk with leaves, two gilded towers on top -->
        <line x1="56" y1="176" x2="144" y2="176" stroke="var(--tri-dark)" stroke-width="3" stroke-linecap="round" />
        <path d="M100 176 C98 150 102 130 100 104" stroke="var(--tri-leaf)" stroke-width="3.5" fill="none" stroke-linecap="round" />
        <path d="M100 150 C84 148 76 138 78 128 C90 132 100 140 100 150 Z" fill="var(--tri-sage)" stroke="var(--tri-leaf)" stroke-width="1.5" />
        <path d="M100 134 C116 132 124 122 122 112 C110 116 100 124 100 134 Z" fill="var(--tri-sage)" stroke="var(--tri-leaf)" stroke-width="1.5" />
        <path d="M82 104 L82 88 L85 88 L85 84 L88 84 L88 88 L90 88 L90 84 L93 84 L93 88 L96 88 L96 104 Z" fill="var(--tri-ochre)" stroke="var(--tri-deep)" stroke-width="1.5" />
        <path d="M104 104 L104 88 L107 88 L107 84 L110 84 L110 88 L112 88 L112 84 L115 84 L115 88 L118 88 L118 104 Z" fill="var(--tri-ochre-2)" stroke="var(--tri-deep)" stroke-width="1.5" />
      </svg>
      <div class="panel__caption">
        <h2 class="panel__name">Projects</h2>
        <p class="panel__desc">Side work and experiments.</p>
      </div>
    </a>

  </div>
</section>

<style>
  .triptych {
    /* Fixed altarpiece palette, internal to this component */
    --tri-gold: #A6822E;
    --tri-deep: #7C5E22;
    --tri-label: #6B4F1A;
    --tri-ground-wing: #E7DBBE;
    --tri-ground-centre: #DFD3B4;
    --tri-teal: #3A6B63;
    --tri-sage: #B4BE96;
    --tri-leaf: #6E7B4E;
    --tri-ochre: #D8B978;
    --tri-ochre-2: #C9A65E;
    --tri-oxblood: #8A4A36;
    --tri-flesh: #E4C9A8;
    --tri-parchment: #F2EAD3;
    --tri-dark: #2A2218;

    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-24);
  }

  .triptych__frame {
    border: 2px solid var(--tri-gold);
    padding: clamp(var(--space-4), 3vw, var(--space-12));
    display: grid;
    grid-template-columns: 1fr 1.3fr 1fr;
    gap: clamp(var(--space-2), 1.5vw, var(--space-6));
    align-items: end;
    justify-items: center;
  }

  .panel {
    position: relative;
    display: block;
    width: 100%;
    text-decoration: none;
  }

  .panel__art {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .panel__framepath {
    fill: var(--tri-gold);
    stroke: var(--tri-deep);
    stroke-width: 2;
  }

  .panel--wing .panel__ground { fill: var(--tri-ground-wing); }
  .panel--centre .panel__ground { fill: var(--tri-ground-centre); }

  .panel__caption {
    position: absolute;
    left: 9%;
    right: 9%;
    bottom: 7%;
    text-align: center;
  }

  .panel__name {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--tri-label);
    font-size: clamp(1.15rem, 2.4vw, 1.9rem);
  }

  .panel--centre .panel__name {
    font-size: clamp(1.4rem, 3vw, 2.4rem);
  }

  .panel__desc {
    margin-top: var(--space-2);
    font-family: var(--font-body);
    font-size: clamp(0.7rem, 1.1vw, 0.95rem);
    line-height: 1.3;
    color: var(--tri-dark);
  }

  @media (max-width: 720px) {
    .triptych__frame {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      align-items: center;
    }
    .panel {
      max-width: 340px;
    }
    .panel__name { font-size: 1.6rem; }
    .panel--centre .panel__name { font-size: 1.6rem; }
    .panel__desc { font-size: 0.95rem; }
  }
</style>
