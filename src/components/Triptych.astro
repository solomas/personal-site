---
// Triptych altarpiece, painterly repaint.
// Each panel is an abstract, surreal SVG painting, a loose three-part homage to
// Bosch, not a copy. Painting techniques: radial gradients with off-centre light,
// blurred atmosphere haze (feGaussianBlur), radial glow fields, a feTurbulence
// grain overlay for canvas tooth, organic hand-drawn paths and layered
// translucent shapes.
//
// Palette is keyed to the two site themes via the same data-theme mechanism
// Layout uses. The flip (black) theme is the primary look: bright forms on a
// near-black field, gilded gold frame, warm glows. The default (yellow) theme
// inverts to dark forms and deep gold on a warm amber field, dark gilded frame.
//
// Structure, open-on-load grisaille, hover and tap expand, carousel and
// reduced-motion handling are unchanged. Grisaille = desaturate .panel__scene,
// the frame sits outside that group so it stays gold.
---
<section class="triptych" data-state="open" aria-label="Three streams of work">
  <div class="triptych__frame">

    <a href="/research/" class="panel panel--wing">
      <svg class="panel__art" viewBox="0 0 200 340" role="img" aria-label="Research panel" focusable="false">
        <defs>
          <linearGradient id="frame-r" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="var(--tri-frame-hi)" />
            <stop offset="0.5" stop-color="var(--tri-frame-mid)" />
            <stop offset="1" stop-color="var(--tri-frame-lo)" />
          </linearGradient>
          <radialGradient id="ground-r" cx="0.5" cy="0.42" r="0.78">
            <stop offset="0" stop-color="var(--tri-ground-hi)" />
            <stop offset="0.55" stop-color="var(--tri-ground-mid)" />
            <stop offset="1" stop-color="var(--tri-ground-lo)" />
          </radialGradient>
          <radialGradient id="glow-r" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color="var(--tri-glow)" stop-opacity="0.5" />
            <stop offset="0.6" stop-color="var(--tri-glow)" stop-opacity="0.16" />
            <stop offset="1" stop-color="var(--tri-glow)" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="iris-r" cx="0.4" cy="0.36" r="0.72">
            <stop offset="0" stop-color="var(--tri-light)" />
            <stop offset="0.45" stop-color="var(--tri-form)" />
            <stop offset="1" stop-color="var(--tri-deep)" />
          </radialGradient>
          <radialGradient id="sclera-r" cx="0.5" cy="0.4" r="0.85">
            <stop offset="0" stop-color="var(--tri-form-soft)" stop-opacity="0.92" />
            <stop offset="1" stop-color="var(--tri-form-soft)" stop-opacity="0.3" />
          </radialGradient>
          <radialGradient id="orb-r" cx="0.38" cy="0.34" r="0.75">
            <stop offset="0" stop-color="var(--tri-light)" />
            <stop offset="0.5" stop-color="var(--tri-form)" />
            <stop offset="1" stop-color="var(--tri-deep)" />
          </radialGradient>
          <filter id="soft-r" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="9" />
          </filter>
          <filter id="grain-r" x="-5%" y="-5%" width="110%" height="110%">
            <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="2" stitchTiles="stitch" result="n" />
            <feColorMatrix in="n" type="saturate" values="0" result="g" />
            <feComponentTransfer in="g"><feFuncA type="table" tableValues="1 1" /></feComponentTransfer>
          </filter>
          <clipPath id="clip-r">
            <path d="M18 322 L18 134 Q18 56 100 26 Q182 56 182 134 L182 322 Z" />
          </clipPath>
        </defs>
        <path class="panel__framepath" d="M8 332 L8 132 Q8 44 100 12 Q192 44 192 132 L192 332 Z" fill="url(#frame-r)" />
        <g class="panel__scene">
          <path class="panel__ground" d="M18 322 L18 134 Q18 56 100 26 Q182 56 182 134 L182 322 Z" fill="url(#ground-r)" />
