<style>
  .triptych {
    /* Default (yellow) theme: dark forms and deep gold on a warm amber field.
       Inverted from the dark theme so it still reads as a painting, not a
       washed-out copy. */
    --tri-ground-hi: #F2BE12;
    --tri-ground-mid: #D9A200;
    --tri-ground-lo: #9A6E00;
    --tri-glow: #F4D27A;
    --tri-atmos: #9A6E00;
    --tri-form: #14110A;
    --tri-form-soft: #3A2C12;
    --tri-light: #B8862E;
    --tri-deep: #0B0905;
    --tri-gold: #8A6A24;
    --tri-label: #1A140A;
    /* Carved dark-wood frame, dark in both themes; gild and relief shift below. */
    --wood-hi: #5A4632;
    --wood-mid: #382A1B;
    --wood-lo: #241A10;
    --wood-edge-light: #6E563A;
    --wood-edge-dark: #140E08;
    --ease: cubic-bezier(0.22, 1, 0.36, 1);

    position: relative;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-24);
  }

  /* Flip (black) theme, the primary look: bright yellow and warm white forms,
     gilded gold frame and warm glows on a near-black field. */
  :global([data-theme="flip"]) .triptych {
    --tri-ground-hi: #000000;
    --tri-ground-mid: #000000;
    --tri-ground-lo: #000000;
    --tri-glow: #FFD60A;
    --tri-atmos: #241A10;
    --tri-form: #FFD60A;
    --tri-form-soft: #F6ECC8;
    --tri-light: #FFF7DC;
    --tri-deep: #2A2218;
    --tri-gold: #C9A24E;
    --tri-label: #F6ECC8;
    --wood-hi: #4A3A28;
    --wood-mid: #2E2318;
    --wood-lo: #18120B;
    --wood-edge-light: #6B5436;
    --wood-edge-dark: #0E0A05;
  }

  /* One connected carved frame: equal-width panels butt together with no gap so
     the half-posts on shared edges merge into shared posts, the base bands form
     one continuous base and the shaped tops flow into one cresting silhouette. */
  .triptych__frame {
    display: flex;
    align-items: flex-end;
    gap: 0;
    perspective: 2000px;
    perspective-origin: center 42%;
  }

  .panel {
    position: relative;
    display: block;
    flex: 1 1 0;
    min-width: 0;
    text-decoration: none;
    transform-style: preserve-3d;
    /* Per-panel stagger for the first-visit door turn, a left-to-right sequence. */
    --p-delay: 0ms;
    transition: transform 780ms var(--ease) var(--p-delay);
  }
  .panel:nth-child(2) { --p-delay: 280ms; }
  .panel:nth-child(3) { --p-delay: 560ms; }
  /* Hinge: wings from their outer edges, centre from its centre line. */
  .panel--wing:first-child { transform-origin: left center; }
  .panel--centre { transform-origin: center center; }
  .panel--wing:last-child { transform-origin: right center; }

  .panel:focus-visible {
    outline: 3px solid var(--tri-gold);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* In-place hover emphasis. The one-piece frame is fixed, so panels never
     resize. The focused painting (.panel__lift) lifts and a soft-light veil
     brightens it, while the other two take a dark veil. All share one 720ms
     ease so the whole piece settles as one motion with no jitter between panels. */
  .panel__lift {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 720ms var(--ease);
  }
  .panel__veil {
    transition: opacity 720ms var(--ease);
    pointer-events: none;
  }
  .panel:hover .panel__lift,
  .panel:focus-visible .panel__lift,
  .panel.is-active .panel__lift {
    transform: translateY(-9px) scale(1.025);
  }
  .panel:hover .panel__veil--lift,
  .panel:focus-visible .panel__veil--lift,
  .panel.is-active .panel__veil--lift {
    opacity: 0.5;
  }
  .triptych__frame:has(.panel:hover) .panel:not(:hover) .panel__veil--dim,
  .triptych__frame:has(.panel:focus-visible) .panel:not(:focus-visible) .panel__veil--dim,
  .triptych__frame.has-active .panel:not(.is-active) .panel__veil--dim {
    opacity: 0.45;
  }

  .panel__art {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
    backface-visibility: hidden;
  }

  /* Scale the art in slightly so the whole scene sits inside the opening with a
     margin, never touching the wood edge. */
  .panel__forms {
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.95);
  }

  /* First-visit turn-to-open. The carved frame plus painting is the front face;
     a plain carved-wood back face (.panel__door) is the shut door, only shown
     while the panel is turned away (backface-visibility). The script adds
     data-turn before paint to rotate each panel closed, then releases it so they
     turn open on their hinge one after another, left to right. */
  .panel__door {
    position: absolute;
    inset: 0;
    background: linear-gradient(118deg, var(--wood-hi), var(--wood-mid) 55%, var(--wood-lo));
    border: 1px solid var(--wood-edge-dark);
    box-shadow:
      inset 0 0 0 5px rgba(0, 0, 0, 0.16),
      inset 0 0 26px rgba(0, 0, 0, 0.34);
    backface-visibility: hidden;
    transform: rotateY(180deg);
  }

  .triptych[data-turn] .panel--wing:first-child { transform: rotateY(-100deg); }
  .triptych[data-turn] .panel--centre { transform: rotateY(90deg); }
  .triptych[data-turn] .panel--wing:last-child { transform: rotateY(100deg); }

  /* Captions sit in the lower part of each opening, above the carved base band,
     over clear painting, so no backing is needed. */
  .panel__caption {
    position: absolute;
    left: 13%;
    right: 13%;
    bottom: 13%;
    text-align: center;
    backface-visibility: hidden;
    transform: translateZ(1px);
  }

  .panel__name {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--tri-label);
    font-size: clamp(1.05rem, 2.1vw, 1.7rem);
  }

  .panel__desc {
    margin-top: var(--space-2);
    font-family: var(--font-body);
    font-size: clamp(0.68rem, 1vw, 0.92rem);
    line-height: 1.3;
    color: var(--tri-label);
    opacity: 0.78;
  }

  /* Narrow screens: the one-piece frame cannot carousel, so it resolves into a
     swipeable carousel where each panel carries its own organic wood crown.
     Restoring the gap separates the butt-joined posts back into per-panel
     framed crowns, one panel mostly in view, swipe to move. */
  @media (max-width: 720px) {
    .triptych__frame {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      align-items: center;
      gap: var(--space-4);
      scroll-padding: var(--space-4);
      perspective: none;
    }
    .panel {
      flex: 0 0 86%;
      scroll-snap-align: center;
    }
    /* The carousel cannot hold a 3D turn, so it renders open with no door. */
    .triptych[data-turn] .panel--wing:first-child,
    .triptych[data-turn] .panel--centre,
    .triptych[data-turn] .panel--wing:last-child { transform: none; }
    .panel__door { display: none; }
    .panel__name { font-size: 1.5rem; }
    .panel__desc { font-size: 0.95rem; }
  }

  /* Reduced motion: render fully open instantly, no turn. Emphasis still
     functions (the veils apply instantly), but with no lift motion and no
     transitions. Full function, no motion. */
  @media (prefers-reduced-motion: reduce) {
    .panel,
    .panel__lift,
    .panel__veil { transition: none !important; }
    .panel:hover .panel__lift,
    .panel:focus-visible .panel__lift,
    .panel.is-active .panel__lift { transform: none !important; }
    .triptych[data-turn] .panel--wing:first-child,
    .triptych[data-turn] .panel--centre,
    .triptych[data-turn] .panel--wing:last-child { transform: none !important; }
  }
</style>

<script is:inline>
  (function () {
    const root = document.querySelector(".triptych");
    if (!root) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isTouch = window.matchMedia("(hover: none)").matches;
    const isNarrow = () => window.matchMedia("(max-width: 720px)").matches;

    let opened = false;
    try { opened = localStorage.getItem("triptych-opened") === "1"; } catch (e) {}

    // Markup ships open, so reduced-motion users and return visits (flag set)
    // render fully open immediately with no turn. A first-ever visit turns open:
    // set the shut state before paint to rotate each panel closed (the wood door
    // facing out), release it on the next frame so they turn open on their hinge
    // one after another left to right, then set the flag when the last lands.
    if (!reduceMotion && !opened) {
      root.dataset.turn = "shut";
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          root.removeAttribute("data-turn");
        });
      });
      // Last panel: 560ms stagger + 780ms turn, set the flag once it lands.
      window.setTimeout(function () {
        try { localStorage.setItem("triptych-opened", "1"); } catch (e) {}
      }, 1500);
    }

    // Touch emphasis on wide layouts: first tap selects and emphasises a panel
    // (lift plus brighten, the others dim), a second tap on it follows the link.
    // In the narrow carousel taps navigate straight away.
    if (isTouch) {
      const frame = root.querySelector(".triptych__frame");
      const panels = Array.prototype.slice.call(root.querySelectorAll(".panel"));
      panels.forEach(function (panel) {
        panel.addEventListener("click", function (e) {
          if (isNarrow()) return;
          if (!panel.classList.contains("is-active")) {
            e.preventDefault();
            panels.forEach(function (p) { p.classList.remove("is-active"); });
            panel.classList.add("is-active");
            if (frame) frame.classList.add("has-active");
          }
        });
      });
    }
  })();
</script>
