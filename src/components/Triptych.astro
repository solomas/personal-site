---
// Typographic triptych, the landing hero, as three stacked editorial rows
// (Paradiso style). Each row is a full-width open band linking to a stream:
// Research, Work, Projects. All three rows are identical open bands on
// --color-bg; the Work band keeps the centre dominance by size alone (tallest
// row, largest title). Thick --color-text rules divide the bands.
//
// Each row is a 3-row grid: kicker (top), an oversized title that is cut off by
// the frame on both sides (a fixed negative left offset forces the cut-off even
// for short words; long titles also run off the right), and a foot holding the
// caption and the "View" affordance. The title lives in its own clipped middle
// region, so it can be huge without ever touching the kicker or the foot. A
// large faint accent numeral runs off the right as a second cut-off.
//
// Reveal: each row slides in from the left and fades, staggered top to bottom;
// numerals and titles then rise with a clip-up mask just after their row.
//
// Palette is the real theme tokens, so the whole piece flips with the toggle.
// No internal palette, no SVG illustration. The component owns its height
// budget; index.astro stretches it to the full hero width.
---
<section class="triptych" aria-label="Three streams of work">

  <a href="/research/" class="row">
    <span class="row__num" aria-hidden="true">01</span>
    <div class="row__titlewrap">
      <h2 class="row__title">Research</h2>
    </div>
    <div class="row__foot">
      <p class="row__caption">Doctoral work in planetary health.</p>
      <span class="row__go">
        <span>View</span>
        <span class="row__arrow" aria-hidden="true">&#8594;</span>
      </span>
    </div>
  </a>

  <a href="/work/" class="row row--work">
    <span class="row__num" aria-hidden="true">02</span>
    <div class="row__titlewrap">
      <h2 class="row__title">Work</h2>
    </div>
    <div class="row__foot">
      <p class="row__caption">Consulting and programme design.</p>
      <span class="row__go">
        <span>View</span>
        <span class="row__arrow" aria-hidden="true">&#8594;</span>
      </span>
    </div>
  </a>

  <a href="/projects/" class="row">
    <span class="row__num" aria-hidden="true">03</span>
    <div class="row__titlewrap">
      <h2 class="row__title">Projects</h2>
    </div>
    <div class="row__foot">
      <p class="row__caption">Side work and experiments.</p>
      <span class="row__go">
        <span>View</span>
        <span class="row__arrow" aria-hidden="true">&#8594;</span>
      </span>
    </div>
  </a>

</section>

<style>
  /* Stacked column of rows. Owns the height budget so the three bands fill the
     hero under the intro. overflow-x: clip removes any right cut-off with no
     scrollbar; overflow-y stays visible so row focus rings are never cut top or
     bottom. overflow-clip-margin leaves a few px at the container edges. */
  .triptych {
    position: relative;
    display: flex;
    flex-direction: column;
    height: clamp(19rem, calc(100svh - 17rem), 44rem);
    overflow-x: clip;
    overflow-y: visible;
    overflow-clip-margin: 8px;
  }

  /* Each band is a 2-row grid: title region (takes the slack and clips) and
     foot. overflow: hidden clips the title's left and right cut-off and any
     vertical spill, while the focus ring uses an inset offset so it is never
     clipped. */
  .row {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-rows: 1fr auto;
    gap: var(--space-2);
    flex: 1 1 0;
    min-width: 0;
    padding: clamp(var(--space-3), 2.2vw, var(--space-6)) clamp(var(--space-4), 2.4vw, var(--space-8));
    background: var(--color-bg);
    /* Thick Paradiso divider between the bands. */
    border-top: 3px solid var(--color-text);
    text-decoration: none;
    transition: opacity 260ms var(--ease-out), transform 260ms var(--ease-out);
  }
  .row:last-child {
    border-bottom: 3px solid var(--color-text);
  }

  /* Hover fill as a left-to-right sweep rather than a flat colour change. The
     accent layer sits behind the numeral and text and scales in from the left
     edge on hover. Clipped by the row's overflow: hidden. */
  .row::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 300ms var(--ease-out);
    pointer-events: none;
  }

  /* The Work band keeps the dominance by size only: tallest row, largest title.
     No fill, no inversion, same open treatment as the others. */
  .row--work {
    flex: 1.4 1 0;
  }

  /* Large faint accent numeral, vertically centred, running off the right edge
     as a cut-off. translateX(13%) leaves roughly three quarters on screen with a
     quarter past the edge; the row clips it. Low alpha keeps it behind the type. */
  .row__num {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translate(13%, -50%);
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(6rem, 13vh, 11rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-accent);
    opacity: 0.14;
    pointer-events: none;
    user-select: none;
    transition: color 260ms var(--ease-out), opacity 260ms var(--ease-out), transform 300ms var(--ease-out);
  }

  /* Title region: takes the slack above the foot, clips its huge title
     vertically so it never crosses into them. */
  /* Title region clips vertically (overflow-y: clip) so the huge title never
     crosses into the kicker or foot, but stays open horizontally so the title
     can bleed to the hard left edge and off the right; the row's own
     overflow: hidden does the horizontal cut-off at the frame edges. */
  .row__titlewrap {
    position: relative;
    z-index: 2;
    overflow-x: visible;
    overflow-y: clip;
    min-height: 0;
    display: flex;
    align-items: center;
  }

  /* Oversized wordmark: huge, bold, tight tracking, nowrap, lowercase. The
     negative left margin cancels the row's left padding and adds a touch more,
     so the title sits hard against the left frame edge with the first letters
     just cut off, on every row regardless of word length. Long titles also run
     off the right. Tune the extra cut via the trailing 2vw. */
  .row__title {
    margin-left: calc(-1 * clamp(var(--space-4), 2.4vw, var(--space-8)) - 2vw);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.9;
    white-space: nowrap;
    text-transform: lowercase;
    font-size: clamp(4rem, 16vw, 13rem);
    color: var(--color-text);
    transform-origin: left center;
    transition: color 260ms var(--ease-out), transform 280ms var(--ease-out);
  }
  .row--work .row__title {
    font-size: clamp(5rem, 20vw, 17rem);
  }

  /* Foot: caption left, View right. Always its own grid row, so the title can
     never land on it. */
  .row__foot {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-4);
  }
  .row__caption {
    min-width: 0;
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 1.3vw, 0.98rem);
    line-height: 1.4;
    color: var(--color-muted);
    transition: color 260ms var(--ease-out);
  }
  .row__go {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text);
    transition: color 260ms var(--ease-out), transform 280ms var(--ease-out);
  }
  .row__arrow {
    transition: transform 280ms var(--ease-out);
  }

  .row:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: -3px;
  }

  /* Hover, bold. Gated to pointer devices, so it never fires on touch. The row
     fills to --color-text and inverts all its text; the numeral flips to
     --color-bg so it stays readable. Arrow slides. */
  @media (hover: hover) and (pointer: fine) {
    /* Accent sweeps in from the left. */
    .row:hover::before {
      transform: scaleX(1);
    }
    .row:hover .row__title,
    .row:hover .row__caption,
    .row:hover .row__go {
      color: var(--color-bg);
    }
    /* Title grows from its left edge. */
    .row:hover .row__title {
      transform: scale(1.04);
    }
    /* Numeral brightens and drifts a touch left with the sweep. */
    .row:hover .row__num {
      color: var(--color-bg);
      opacity: 0.2;
      transform: translate(calc(13% - 6px), -50%);
    }
    /* Affordance: the label nudges, the arrow travels further. */
    .row:hover .row__go {
      transform: translateX(3px);
    }
    .row:hover .row__arrow {
      transform: translateX(12px);
    }
    /* The other two rows step back so the focus falls on the active one. */
    .triptych:has(.row:hover) .row:not(:hover) {
      opacity: 0.6;
      transform: scale(0.99);
    }
  }

  /* Once-per-visit reveal. Markup ships in the rest position, so reduced motion,
     return visits and no-JS all render fully open and static. On a first visit
     the script sets data-reveal before first paint; fill-mode backwards holds
     each element in its hidden start state until its turn, then it plays once
     and settles into the rest position with nothing lingering.

     Each row slides in from the left and fades, staggered top to bottom
     (Research, then Work, then Projects). Each numeral and title then rises with
     a clip-up mask just after its row lands. One settled ease, no overshoot. */
  .triptych[data-reveal] .row {
    animation: tri-row 560ms var(--ease-out) backwards;
  }
  .triptych[data-reveal] .row:nth-child(1) { animation-delay: 0ms; }
  .triptych[data-reveal] .row:nth-child(2) { animation-delay: 160ms; }
  .triptych[data-reveal] .row:nth-child(3) { animation-delay: 320ms; }

  /* The title rises with a clip-up mask. The numeral uses its own keyframe so
     it keeps its translate(13%, -50%) placement (the shared mask would drop it),
     and it drifts the last few percent into its cut-off rest so the end of the
     reveal settles rather than snapping. Both run a touch longer for a gentler
     tail. No overshoot. */
  .triptych[data-reveal] .row__title {
    animation: tri-rise 460ms var(--ease-out) backwards;
  }
  .triptych[data-reveal] .row__num {
    animation: tri-rise-num 460ms var(--ease-out) backwards;
  }
  .triptych[data-reveal] .row:nth-child(1) .row__num { animation-delay: 320ms; }
  .triptych[data-reveal] .row:nth-child(1) .row__title { animation-delay: 360ms; }
  .triptych[data-reveal] .row:nth-child(2) .row__num { animation-delay: 480ms; }
  .triptych[data-reveal] .row:nth-child(2) .row__title { animation-delay: 520ms; }
  .triptych[data-reveal] .row:nth-child(3) .row__num { animation-delay: 640ms; }
  .triptych[data-reveal] .row:nth-child(3) .row__title { animation-delay: 680ms; }

  @keyframes tri-row {
    from { opacity: 0; transform: translateX(-12%); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes tri-rise {
    from { clip-path: inset(100% 0 -15% 0); transform: translateY(0.35em); }
    to   { clip-path: inset(-15% 0 -15% 0); transform: translateY(0); }
  }
  @keyframes tri-rise-num {
    from { clip-path: inset(100% 0 -15% 0); transform: translate(9%, calc(-50% + 0.35em)); }
    to   { clip-path: inset(-15% 0 -15% 0); transform: translate(13%, -50%); }
  }
  @keyframes tri-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Narrow screens: rows are already stacked, the natural shape. Drop the
     height budget, hide the cut-off numeral, wrap titles smaller with no left
     offset, and replace the slide with a calm staggered fade. Hover falls away
     through the pointer media gate above. */
  @media (max-width: 720px) {
    .triptych {
      height: auto;
    }
    .row,
    .row--work {
      flex: 1 1 auto;
      min-height: 8.5rem;
      grid-template-rows: auto auto;
    }
    .row__num {
      display: none;
    }
    .row__titlewrap {
      overflow: visible;
    }
    .row__title,
    .row--work .row__title {
      margin-left: 0;
      white-space: normal;
      font-size: 2.2rem;
    }
    .triptych[data-reveal] .row {
      animation: tri-fade 420ms var(--ease-out) backwards;
    }
    .triptych[data-reveal] .row:nth-child(1) { animation-delay: 0ms; }
    .triptych[data-reveal] .row:nth-child(2) { animation-delay: 120ms; }
    .triptych[data-reveal] .row:nth-child(3) { animation-delay: 240ms; }
    .triptych[data-reveal] .row__num,
    .triptych[data-reveal] .row__title {
      animation: none;
    }
  }

  /* Reduced motion: no reveal animation and no hover transitions, render and
     respond instantly in the rest position. The script also skips setting
     data-reveal, so the reveal half is belt-and-braces. */
  @media (prefers-reduced-motion: reduce) {
    .triptych[data-reveal] .row,
    .triptych[data-reveal] .row__num,
    .triptych[data-reveal] .row__title {
      animation: none !important;
    }
    .row,
    .row::before,
    .row__num,
    .row__title,
    .row__caption,
    .row__go,
    .row__arrow {
      transition: none !important;
    }
    /* No hover movement: neutralise every transform and the dim. The accent
       fill still appears on hover, but instantly (no sweep) so the hover
       affordance survives without motion. */
    .row:hover .row__title,
    .row:hover .row__go,
    .row:hover .row__arrow {
      transform: none !important;
    }
    .row:hover .row__num {
      transform: translate(13%, -50%) !important;
    }
    .triptych:has(.row:hover) .row:not(:hover) {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    const root = document.querySelector(".triptych");
    if (!root) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let revealed = false;
    try { revealed = localStorage.getItem("triptych-revealed") === "1"; } catch (e) {}

    // Reduced motion and return visits stay in the rest position with no motion.
    // A first visit sets data-reveal before first paint, so the animations'
    // backwards fill shows each element's hidden start state, then they play
    // once. The attribute stays put; the flag makes the next visit skip straight
    // to the rest position.
    if (reduceMotion || revealed) return;

    root.dataset.reveal = "";
    // The sequence ends near the last title at ~1100ms; set the flag after.
    window.setTimeout(function () {
      try { localStorage.setItem("triptych-revealed", "1"); } catch (e) {}
    }, 1600);
  })();
</script>
