              <path d="M126 126 C134 110 140 100 150 88" stroke-width="2" />
              <path d="M58 140 C44 132 36 128 26 122" stroke-width="1.8" />
              <path d="M142 140 C156 132 164 128 174 122" stroke-width="1.8" />
              <path d="M88 118 C84 104 82 96 78 84" stroke-width="1.6" />
              <path d="M112 118 C116 104 118 96 122 84" stroke-width="1.6" />
              <path d="M66 132 C56 120 50 114 42 104" stroke-width="1.5" />
              <path d="M134 132 C144 120 150 114 158 104" stroke-width="1.5" />
