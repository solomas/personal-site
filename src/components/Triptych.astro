<style>
  .triptych {
    /* Default (yellow) theme: dark forms and deep gold on a warm amber field.
       Inverted from the dark theme so it still reads as a painting, not a
       washed-out copy. */
    --tri-ground-hi: #F2BE12;
    --tri-ground-mid: #D9A200;
    --tri-ground-lo: #9A6E00;
    --tri-glow: #F4D27A;
    --tri-atmos: #9A6E00;
    --tri-form: #14110A;
    --tri-form-soft: #3A2C12;
    --tri-light: #B8862E;
    --tri-deep: #0B0905;
    --tri-frame-hi: #8A6A24;
    --tri-frame-mid: #5A4416;
    --tri-frame-lo: #2A2218;
    --tri-gold: #5A4416;
    --tri-label: #1A140A;

    max-width: var(--page-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-8) var(--space-24);
  }

  /* Flip (black) theme, the primary look: bright yellow and warm white forms,
     gilded gold frame and warm glows on a near-black field. */
  :global([data-theme="flip"]) .triptych {
    --tri-ground-hi: #1A160C;
    --tri-ground-mid: #100D08;
    --tri-ground-lo: #060503;
    --tri-glow: #FFD60A;
    --tri-atmos: #C9882E;
    --tri-form: #FFD60A;
    --tri-form-soft: #F6ECC8;
    --tri-light: #FFF7DC;
    --tri-deep: #2A2218;
    --tri-frame-hi: #F2D98A;
    --tri-frame-mid: #C9A24E;
    --tri-frame-lo: #7C5E22;
    --tri-gold: #C9A24E;
    --tri-label: #F6ECC8;
  }

  .triptych__frame {
    border: 2px solid var(--tri-gold);
    padding: clamp(var(--space-4), 3vw, var(--space-12));
    display: flex;
    align-items: flex-end;
    gap: clamp(var(--space-2), 1.5vw, var(--space-6));
    perspective: 1800px;
  }

  .panel {
    position: relative;
    display: block;
    flex: 1 1 0;
    min-width: 0;
    text-decoration: none;
    transform-origin: center center;
    /* Expand is a flex-grow change, the open swing is a transform.
       The swing is slow and weighty so the open reads as deliberate. */
    transition:
      flex-grow 460ms cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 1000ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 1000ms ease;
  }
  .panel--centre { flex-grow: 1.3; }

  /* Expand on pointer hover, neighbours shrink naturally. */
  @media (hover: hover) {
    .panel:hover { flex-grow: 2.4; }
  }
  /* Keyboard focus expands too, regardless of pointer type, and shows a clear
     ring. Expand is purely visual, so focus is never trapped. */
  .panel:focus-visible {
    flex-grow: 2.4;
    outline: 3px solid var(--tri-gold);
    outline-offset: 5px;
  }
  /* Touch expand, driven by the script toggling .is-active. */
  .panel.is-active { flex-grow: 2.4; }

  .panel__art {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .panel__framepath {
    stroke: var(--tri-frame-lo);
    stroke-width: 1.5;
  }

  .panel__scene {
    /* Colour tints in just after the swing begins, a deliberate reveal. */
    transition: filter 1200ms ease 180ms;
  }

  /* Closed grisaille state: desaturate the painted scene, frame stays gold,
     wings swing shut. The script removes data-state="closed" to open. */
  .triptych[data-state="closed"] .panel__scene {
    filter: grayscale(1) contrast(0.92) brightness(1.04);
  }
  .triptych[data-state="closed"] .panel--centre {
    opacity: 0.55;
  }
  .triptych[data-state="closed"] .panel--wing:first-child {
    transform-origin: right center;
    transform: rotateY(-46deg);
    opacity: 0.7;
  }
  .triptych[data-state="closed"] .panel--wing:last-child {
    transform-origin: left center;
    transform: rotateY(46deg);
    opacity: 0.7;
  }

  .panel__caption {
    position: absolute;
    left: 9%;
    right: 9%;
    bottom: 7%;
    text-align: center;
  }

  .panel__name {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--tri-label);
    font-size: clamp(1.15rem, 2.4vw, 1.9rem);
  }
  .panel--centre .panel__name {
    font-size: clamp(1.4rem, 3vw, 2.4rem);
  }

  .panel__desc {
    margin-top: var(--space-2);
    font-family: var(--font-body);
    font-size: clamp(0.7rem, 1.1vw, 0.95rem);
    line-height: 1.3;
    color: var(--tri-label);
    opacity: 0.78;
  }

  /* Narrow screens: horizontal swipeable carousel, one panel mostly in view.
     No swing, no expand, links navigate on a single tap. */
  @media (max-width: 720px) {
    .triptych__frame {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      align-items: center;
      gap: var(--space-4);
      perspective: none;
      scroll-padding: var(--space-4);
    }
    .panel {
      flex: 0 0 80%;
      scroll-snap-align: center;
    }
    .panel--centre { flex-grow: 0; }
    .panel.is-active,
    .panel:focus-visible { flex-grow: 0; }
    .triptych[data-state="closed"] .panel--wing:first-child,
    .triptych[data-state="closed"] .panel--wing:last-child {
      transform: none;
      opacity: 1;
    }
    .panel__name,
    .panel--centre .panel__name { font-size: 1.6rem; }
    .panel__desc { font-size: 0.95rem; }
  }

  /* Reduced motion: render straight to open, no swing, no transitions.
     Expand still functions, just instantly. Full function, no motion. */
  @media (prefers-reduced-motion: reduce) {
    .panel,
    .panel__scene { transition: none !important; }
    .triptych[data-state="closed"] .panel--wing:first-child,
    .triptych[data-state="closed"] .panel--wing:last-child {
      transform: none !important;
      opacity: 1 !important;
    }
    .triptych[data-state="closed"] .panel__scene { filter: none !important; }
    .triptych[data-state="closed"] .panel--centre { opacity: 1 !important; }
  }
</style>

<script is:inline>
  (function () {
    const root = document.querySelector(".triptych");
    if (!root) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isTouch = window.matchMedia("(hover: none)").matches;
    const isNarrow = () => window.matchMedia("(max-width: 720px)").matches;

    // Open once per load. Markup ships open, so drop to closed before paint
    // then flip back on the next frames to animate. Skipped if reduced motion.
    if (!reduceMotion) {
      root.dataset.state = "closed";
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          root.dataset.state = "open";
        });
      });
    }

    // Touch expand on wide layouts: first tap expands, second tap follows the
    // link. In the narrow carousel taps navigate straight away.
    if (isTouch) {
      const panels = Array.prototype.slice.call(root.querySelectorAll(".panel"));
      panels.forEach(function (panel) {
        panel.addEventListener("click", function (e) {
          if (isNarrow()) return;
          if (!panel.classList.contains("is-active")) {
            e.preventDefault();
            panels.forEach(function (p) { p.classList.remove("is-active"); });
            panel.classList.add("is-active");
          }
        });
      });
    }
  })();
</script>
