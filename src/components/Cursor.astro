---
---
<div id="cursor-dot" class="cursor-dot" aria-hidden="true"></div>
<div id="cursor-ring" class="cursor-ring" aria-hidden="true"></div>

<style>
  .cursor-dot,
  .cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: opacity 200ms ease, width 200ms ease, height 200ms ease, background-color 200ms ease, border-color 200ms ease, transform 80ms ease-out;
    will-change: transform;
  }
  .cursor-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-accent);
    transform: translate(-50%, -50%);
  }
  .cursor-ring {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    background: transparent;
    transform: translate(-50%, -50%) scale(0.4);
    transition: transform 180ms ease, width 180ms ease, height 180ms ease, opacity 180ms ease, border-color 200ms ease;
  }
  .cursor-dot.is-active {
    opacity: 1;
  }
  .cursor-ring.is-active {
    opacity: 0.6;
  }
  .cursor-ring.is-active.is-hover {
    opacity: 1;
  }
  /* On interactive hover the ring grows to 1.6x. Colour stays --color-accent in
     every state, so the cursor is always the page-background contrast colour
     (black on the yellow theme, yellow on the flip theme). */
  .cursor-ring.is-hover {
    transform: translate(-50%, -50%) scale(1.6);
    border-color: var(--color-accent);
  }
  .cursor-dot.is-hover {
    background-color: var(--color-accent);
  }
  /* Over a hovered triptych row the banner fills with --color-accent, so the
     cursor would be accent-on-accent and vanish. Flip it to --color-bg there to
     keep contrast (black on the yellow banner in flip, yellow on the black
     banner in default). Wins over the .is-hover colour by source order. */
  .cursor-dot.is-on-row {
    background-color: var(--color-bg);
  }
  .cursor-ring.is-on-row {
    border-color: var(--color-bg);
  }

  /* Hide on touch devices and reduced motion */
  @media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
    .cursor-dot, .cursor-ring { display: none !important; }
  }
</style>

<script>
  const dot = document.getElementById("cursor-dot");
  const ring = document.getElementById("cursor-ring");
  if (dot && ring && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
    let mouseX = 0, mouseY = 0;
    let ringX = 0, ringY = 0;
    let raf = 0;

    function activate() {
      dot.classList.add("is-active");
      ring.classList.add("is-active");
    }

    window.addEventListener("mousemove", (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      dot.style.transform = `translate(${mouseX}px, ${mouseY}px) translate(-50%, -50%)`;
      activate();
      if (!raf) raf = requestAnimationFrame(animateRing);
    }, { passive: true });

    function animateRing() {
      ringX += (mouseX - ringX) * 0.25;
      ringY += (mouseY - ringY) * 0.25;
      ring.style.transform = `translate(${ringX}px, ${ringY}px) translate(-50%, -50%) ${ring.classList.contains("is-hover") ? "scale(1.6)" : "scale(0.4)"}`;
      if (Math.abs(mouseX - ringX) > 0.1 || Math.abs(mouseY - ringY) > 0.1) {
        raf = requestAnimationFrame(animateRing);
      } else {
        raf = 0;
      }
    }

    window.addEventListener("mouseleave", () => {
      dot.classList.remove("is-active");
      ring.classList.remove("is-active");
    });
    window.addEventListener("mouseenter", activate);

    const interactiveSelector = "a, button, [role='button'], input, textarea, select, summary, [data-cursor='hover'], .work-card, .other-work-header, .archived-card";
    document.addEventListener("mouseover", (e) => {
      const target = e.target;
      if (target instanceof Element && target.closest(interactiveSelector)) {
        dot.classList.add("is-hover");
        ring.classList.add("is-hover");
      }
    });
    document.addEventListener("mouseout", (e) => {
      const target = e.target;
      if (target instanceof Element && target.closest(interactiveSelector)) {
        dot.classList.remove("is-hover");
        ring.classList.remove("is-hover");
      }
    });

    // Flip the cursor colour while inside a triptych row, which fills with
    // --color-accent on hover. mouseenter/leave fire on the row boundary only,
    // not on inner children, so there is no flicker as the pointer crosses the
    // title or foot.
    document.querySelectorAll(".row").forEach((row) => {
      row.addEventListener("mouseenter", () => {
        dot.classList.add("is-on-row");
        ring.classList.add("is-on-row");
      });
      row.addEventListener("mouseleave", () => {
        dot.classList.remove("is-on-row");
        ring.classList.remove("is-on-row");
      });
    });
  }
</script>
